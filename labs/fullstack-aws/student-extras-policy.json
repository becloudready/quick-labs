{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "ResourceGroupsTagging",
      "Effect": "Allow",
      "Action": [
        "tag:GetResources",
        "tag:TagResources",
        "tag:UntagResources",
        "tag:GetTagKeys",
        "tag:GetTagValues"
      ],
      "Resource": "*"
    },
    {
      "Sid": "IamPolicyReadGlobal",
      "Effect": "Allow",
      "Action": [
        "iam:GetPolicy",
        "iam:GetPolicyVersion",
        "iam:ListUsers",
        "iam:ListGroups"
      ],
      "Resource": "*"
    },
    {
      "Sid": "ApiGatewayConsoleSupport",
      "Effect": "Allow",
      "Action": "apigateway:GET",
      "Resource": [
        "arn:aws:apigateway:us-east-1::/account",
        "arn:aws:apigateway:us-east-1::/usageplans",
        "arn:aws:apigateway:us-east-1::/usageplans/*",
        "arn:aws:apigateway:us-east-1::/apikeys",
        "arn:aws:apigateway:us-east-1::/apikeys/*",
        "arn:aws:apigateway:us-east-1::/vpclinks",
        "arn:aws:apigateway:us-east-1::/vpclinks/*",
        "arn:aws:apigateway:us-east-1::/domainnames",
        "arn:aws:apigateway:us-east-1::/domainnames/*"
      ]
    },
    {
      "Sid": "XRayReadOnly",
      "Effect": "Allow",
      "Action": [
        "xray:GetTraceSummaries",
        "xray:BatchGetTraces",
        "xray:GetServiceGraph",
        "xray:GetTraceGraph"
      ],
      "Resource": "*"
    },
    {
      "Sid": "SelfServiceVirtualMFADevice",
      "Effect": "Allow",
      "Action": [
        "iam:CreateVirtualMFADevice",
        "iam:DeleteVirtualMFADevice"
      ],
      "Resource": "arn:aws:iam::{ACCOUNT_ID}:mfa/*"
    },
    {
      "Sid": "SelfServiceEnableOwnMFA",
      "Effect": "Allow",
      "Action": [
        "iam:EnableMFADevice",
        "iam:DeactivateMFADevice",
        "iam:GetMFADevice",
        "iam:ResyncMFADevice"
      ],
      "Resource": "arn:aws:iam::{ACCOUNT_ID}:user/${aws:username}"
    },
    {
      "Sid": "ListVirtualMFADevicesForConsole",
      "Effect": "Allow",
      "Action": "iam:ListVirtualMFADevices",
      "Resource": "*"
    },
    {
      "Sid": "LogsInsightsQuery",
      "Effect": "Allow",
      "Action": [
        "logs:StartQuery",
        "logs:StopQuery",
        "logs:GetQueryResults",
        "logs:DescribeQueries",
        "logs:DescribeSubscriptionFilters",
        "logs:GetLogGroupFields",
        "logs:GetLogRecord"
      ],
      "Resource": "*"
    },
    {
      "Sid": "Wafv2ReadList",
      "Effect": "Allow",
      "Action": [
        "wafv2:List*",
        "wafv2:Get*",
        "wafv2:Describe*",
        "wafv2:CheckCapacity"
      ],
      "Resource": "*"
    },
    {
      "Sid": "Wafv2NamespacedMutations",
      "Effect": "Allow",
      "Action": [
        "wafv2:CreateWebACL",
        "wafv2:UpdateWebACL",
        "wafv2:DeleteWebACL",
        "wafv2:CreateIPSet",
        "wafv2:UpdateIPSet",
        "wafv2:DeleteIPSet",
        "wafv2:CreateRuleGroup",
        "wafv2:UpdateRuleGroup",
        "wafv2:DeleteRuleGroup",
        "wafv2:CreateRegexPatternSet",
        "wafv2:UpdateRegexPatternSet",
        "wafv2:DeleteRegexPatternSet",
        "wafv2:AssociateWebACL",
        "wafv2:DisassociateWebACL",
        "wafv2:TagResource",
        "wafv2:UntagResource",
        "wafv2:PutLoggingConfiguration",
        "wafv2:DeleteLoggingConfiguration"
      ],
      "Resource": [
        "arn:aws:wafv2:us-east-1:{ACCOUNT_ID}:global/webacl/student-${aws:PrincipalTag/slug}-*/*",
        "arn:aws:wafv2:us-east-1:{ACCOUNT_ID}:global/ipset/student-${aws:PrincipalTag/slug}-*/*",
        "arn:aws:wafv2:us-east-1:{ACCOUNT_ID}:global/rulegroup/student-${aws:PrincipalTag/slug}-*/*",
        "arn:aws:wafv2:us-east-1:{ACCOUNT_ID}:global/regexpatternset/student-${aws:PrincipalTag/slug}-*/*",
        "arn:aws:wafv2:us-east-1:{ACCOUNT_ID}:regional/webacl/student-${aws:PrincipalTag/slug}-*/*",
        "arn:aws:wafv2:us-east-1:{ACCOUNT_ID}:regional/ipset/student-${aws:PrincipalTag/slug}-*/*",
        "arn:aws:wafv2:us-east-1:{ACCOUNT_ID}:regional/rulegroup/student-${aws:PrincipalTag/slug}-*/*",
        "arn:aws:wafv2:us-east-1:{ACCOUNT_ID}:regional/regexpatternset/student-${aws:PrincipalTag/slug}-*/*",
        "arn:aws:wafv2:us-east-1:{ACCOUNT_ID}:global/managedruleset/*/*",
        "arn:aws:wafv2:us-east-1:{ACCOUNT_ID}:regional/managedruleset/*/*"
      ]
    }
  ]
}
