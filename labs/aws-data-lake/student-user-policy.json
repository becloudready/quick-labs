{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "DenyOutsideUSWest2",
      "Effect": "Deny",
      "NotAction": [
        "iam:*",
        "sts:*",
        "s3:ListAllMyBuckets",
        "s3:GetBucketLocation",
        "s3:HeadBucket",
        "athena:ListWorkGroups",
        "athena:ListDataCatalogs",
        "athena:ListEngineVersions",
        "support:*",
        "ce:*",
        "health:*",
        "notifications:*",
        "servicecatalog:ListApplications",
        "ec2:DescribeRegions",
        "ec2:DescribeAvailabilityZones"
      ],
      "Resource": "*",
      "Condition": {
        "StringNotEqualsIfExists": {
          "aws:RequestedRegion": "us-west-2"
        }
      }
    },
    {
      "Sid": "ConsoleNavGlobals",
      "Effect": "Allow",
      "Action": [
        "s3:ListAllMyBuckets",
        "s3:GetBucketLocation",
        "s3:HeadBucket",
        "sts:GetCallerIdentity",
        "athena:ListWorkGroups",
        "athena:ListDataCatalogs",
        "athena:ListEngineVersions"
      ],
      "Resource": "*"
    },
    {
      "Sid": "ConsoleChrome",
      "Effect": "Allow",
      "Action": [
        "notifications:ListNotificationHubs",
        "notifications:ListChannels",
        "notifications:ListEventRules",
        "notifications:ListNotificationEvents",
        "servicecatalog:ListApplications",
        "ec2:DescribeRegions",
        "ec2:DescribeAvailabilityZones"
      ],
      "Resource": "*"
    },
    {
      "Sid": "ReadOwnIamUser",
      "Effect": "Allow",
      "Action": [
        "iam:GetUser",
        "iam:ListAccessKeys",
        "iam:ListGroupsForUser",
        "iam:ListAttachedUserPolicies",
        "iam:ListUserPolicies",
        "iam:GetUserPolicy",
        "iam:ChangePassword"
      ],
      "Resource": "arn:aws:iam::{ACCOUNT_ID}:user/quicklabs-{USERNAME}"
    },
    {
      "Sid": "ManageOwnVirtualMFADevice",
      "Effect": "Allow",
      "Action": [
        "iam:CreateVirtualMFADevice",
        "iam:DeleteVirtualMFADevice"
      ],
      "Resource": "arn:aws:iam::{ACCOUNT_ID}:mfa/quicklabs-{USERNAME}*"
    },
    {
      "Sid": "ManageMFAOnOwnUser",
      "Effect": "Allow",
      "Action": [
        "iam:DeactivateMFADevice",
        "iam:EnableMFADevice",
        "iam:ListMFADevices",
        "iam:ResyncMFADevice"
      ],
      "Resource": "arn:aws:iam::{ACCOUNT_ID}:user/quicklabs-{USERNAME}"
    },
    {
      "Sid": "ListVirtualMFADevices",
      "Effect": "Allow",
      "Action": "iam:ListVirtualMFADevices",
      "Resource": "*"
    },
    {
      "Sid": "ReadIamRolesForGlueConsole",
      "Effect": "Allow",
      "Action": [
        "iam:GetRole",
        "iam:GetRolePolicy",
        "iam:ListRolePolicies",
        "iam:ListAttachedRolePolicies",
        "iam:ListRoles"
      ],
      "Resource": "*"
    },
    {
      "Sid": "PolicySimulator",
      "Effect": "Allow",
      "Action": [
        "iam:SimulateCustomPolicy",
        "iam:SimulatePrincipalPolicy",
        "iam:GetPolicy",
        "iam:GetPolicyVersion",
        "iam:ListPolicies",
        "iam:ListUsers"
      ],
      "Resource": "*"
    },
    {
      "Sid": "S3CreateOwnBuckets",
      "Effect": "Allow",
      "Action": [
        "s3:CreateBucket",
        "s3:DeleteBucket",
        "s3:PutBucketPolicy",
        "s3:DeleteBucketPolicy",
        "s3:GetBucketPolicy",
        "s3:PutBucketTagging",
        "s3:GetBucketTagging",
        "s3:PutBucketVersioning",
        "s3:GetBucketVersioning",
        "s3:PutBucketEncryption",
        "s3:GetEncryptionConfiguration",
        "s3:PutBucketPublicAccessBlock",
        "s3:GetBucketPublicAccessBlock",
        "s3:PutLifecycleConfiguration",
        "s3:GetLifecycleConfiguration",
        "s3:PutBucketAcl",
        "s3:GetBucketAcl"
      ],
      "Resource": "arn:aws:s3:::quicklabs-{USERNAME}-*",
      "Condition": {
        "StringEqualsIfExists": {
          "aws:RequestedRegion": "us-west-2"
        }
      }
    },
    {
      "Sid": "S3FullAccessOwnBuckets",
      "Effect": "Allow",
      "Action": ["s3:*"],
      "Resource": [
        "arn:aws:s3:::quicklabs-{USERNAME}-*",
        "arn:aws:s3:::quicklabs-{USERNAME}-*/*"
      ]
    },
    {
      "Sid": "GlueCatalogNav",
      "Effect": "Allow",
      "Action": [
        "glue:Get*",
        "glue:List*",
        "glue:BatchGet*",
        "glue:SearchTables"
      ],
      "Resource": "*"
    },
    {
      "Sid": "GlueOwnDatabasesAndTables",
      "Effect": "Allow",
      "Action": ["glue:*"],
      "Resource": [
        "arn:aws:glue:us-west-2:{ACCOUNT_ID}:catalog",
        "arn:aws:glue:us-west-2:{ACCOUNT_ID}:database/quicklabs_{USERNAME_UNDERSCORED}_*",
        "arn:aws:glue:us-west-2:{ACCOUNT_ID}:table/quicklabs_{USERNAME_UNDERSCORED}_*/*",
        "arn:aws:glue:us-west-2:{ACCOUNT_ID}:userDefinedFunction/quicklabs_{USERNAME_UNDERSCORED}_*/*"
      ]
    },
    {
      "Sid": "GlueCrawlersJobsTriggersConnectionsCohortWide",
      "Effect": "Allow",
      "Action": ["glue:*"],
      "Resource": [
        "arn:aws:glue:us-west-2:{ACCOUNT_ID}:crawler/*",
        "arn:aws:glue:us-west-2:{ACCOUNT_ID}:job/*",
        "arn:aws:glue:us-west-2:{ACCOUNT_ID}:trigger/*",
        "arn:aws:glue:us-west-2:{ACCOUNT_ID}:connection/*"
      ]
    },
    {
      "Sid": "GlueOwnSessions",
      "Effect": "Allow",
      "Action": ["glue:*"],
      "Resource": [
        "arn:aws:glue:us-west-2:{ACCOUNT_ID}:session/quicklabs-{USERNAME}-*"
      ]
    },
    {
      "Sid": "AthenaOwnWorkgroup",
      "Effect": "Allow",
      "Action": [
        "athena:StartQueryExecution",
        "athena:StopQueryExecution",
        "athena:GetQueryExecution",
        "athena:GetQueryResults",
        "athena:GetQueryResultsStream",
        "athena:ListQueryExecutions",
        "athena:BatchGetQueryExecution",
        "athena:GetWorkGroup",
        "athena:UpdateWorkGroup",
        "athena:CreateNamedQuery",
        "athena:DeleteNamedQuery",
        "athena:GetNamedQuery",
        "athena:ListNamedQueries",
        "athena:CreatePreparedStatement",
        "athena:DeletePreparedStatement",
        "athena:GetPreparedStatement",
        "athena:ListPreparedStatements"
      ],
      "Resource": "arn:aws:athena:us-west-2:{ACCOUNT_ID}:workgroup/quicklabs-{USERNAME}-wg"
    },
    {
      "Sid": "AthenaCatalogRead",
      "Effect": "Allow",
      "Action": [
        "athena:GetDataCatalog",
        "athena:GetDatabase",
        "athena:ListDatabases",
        "athena:GetTableMetadata",
        "athena:ListTableMetadata"
      ],
      "Resource": "arn:aws:athena:us-west-2:{ACCOUNT_ID}:datacatalog/AwsDataCatalog"
    },
    {
      "Sid": "PassOwnGlueRole",
      "Effect": "Allow",
      "Action": ["iam:PassRole"],
      "Resource": "arn:aws:iam::{ACCOUNT_ID}:role/quicklabs-{USERNAME}-glue-role",
      "Condition": {
        "StringEquals": {
          "iam:PassedToService": "glue.amazonaws.com"
        }
      }
    },
    {
      "Sid": "ReadGlueExecutionLogs",
      "Effect": "Allow",
      "Action": [
        "logs:DescribeLogGroups",
        "logs:DescribeLogStreams",
        "logs:GetLogEvents",
        "logs:FilterLogEvents"
      ],
      "Resource": [
        "arn:aws:logs:us-west-2:{ACCOUNT_ID}:log-group:/aws-glue/*",
        "arn:aws:logs:us-west-2:{ACCOUNT_ID}:log-group:/aws-glue/*:*"
      ]
    },
    {
      "Sid": "GlueJobMonitoring",
      "Effect": "Allow",
      "Action": [
        "cloudwatch:GetMetricData",
        "cloudwatch:GetMetricStatistics",
        "cloudwatch:ListMetrics",
        "logs:StartQuery",
        "logs:StopQuery",
        "logs:GetQueryResults",
        "logs:DescribeQueries",
        "application-autoscaling:Describe*",
        "tag:GetResources",
        "pricing:GetProducts",
        "pricing:DescribeServices"
      ],
      "Resource": "*"
    }
  ]
}
