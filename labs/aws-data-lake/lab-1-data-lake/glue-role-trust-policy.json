{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "GlueServiceCanAssume",
      "Effect": "Allow",
      "Principal": {
        "Service": "glue.amazonaws.com"
      },
      "Action": "sts:AssumeRole"
    },
    {
      "Sid": "StudentCanAssumeForInteractiveSessions",
      "Effect": "Allow",
      "Principal": {
        "AWS": "arn:aws:iam::{ACCOUNT_ID}:user/quicklabs-{USERNAME}"
      },
      "Action": "sts:AssumeRole"
    }
  ]
}
