{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "AccessStudentBuckets",
      "Effect": "Allow",
      "Action": [
        "s3:GetObject",
        "s3:PutObject",
        "s3:DeleteObject",
        "s3:ListBucket",
        "s3:GetBucketLocation"
      ],
      "Resource": [
        "arn:aws:s3:::quicklabs-{USERNAME}-*",
        "arn:aws:s3:::quicklabs-{USERNAME}-*/*"
      ]
    },
    {
      "Sid": "DenyCatalogTableWritesOutsideOwnNamespace",
      "Effect": "Deny",
      "Action": [
        "glue:CreateTable",
        "glue:UpdateTable",
        "glue:DeleteTable",
        "glue:BatchDeleteTable",
        "glue:CreatePartition",
        "glue:UpdatePartition",
        "glue:DeletePartition",
        "glue:BatchCreatePartition",
        "glue:BatchDeletePartition",
        "glue:BatchUpdatePartition",
        "glue:UpdateDatabase",
        "glue:DeleteDatabase"
      ],
      "NotResource": [
        "arn:aws:glue:us-west-2:{ACCOUNT_ID}:catalog",
        "arn:aws:glue:us-west-2:{ACCOUNT_ID}:database/quicklabs_{USERNAME_UNDERSCORED}_*",
        "arn:aws:glue:us-west-2:{ACCOUNT_ID}:table/quicklabs_{USERNAME_UNDERSCORED}_*/*"
      ]
    }
  ]
}
